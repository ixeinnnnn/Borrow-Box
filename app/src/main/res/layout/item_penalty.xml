<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_penalty.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Name + Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPenaltyUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Juan dela Cruz"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tvPaymentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_status_pending"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Unpaid"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:fontFamily="@font/poppins_medium" />
        </LinearLayout>

        <!-- Item Name -->
        <TextView
            android:id="@+id/tvPenaltyItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Folding Chairs (x4)"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="@color/divider_color" />

        <!-- Bottom row: dates + cost -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Borrow Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Borrowed"
                    android:textColor="@color/hint_color"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvBorrowDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apr 20, 2026"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium" />
            </LinearLayout>

            <!-- Due Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due Date"
                    android:textColor="@color/hint_color"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apr 22, 2026"
                    android:textColor="@color/red_overdue"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium" />
            </LinearLayout>

            <!-- Penalty Cost -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Penalty"
                    android:textColor="@color/hint_color"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvPenaltyCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱50.00"
                    android:textColor="@color/red_overdue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mark as Paid Button (shown when Unpaid or Waived) -->
        <Button
            android:id="@+id/btnMarkPaid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_primary_rounded"
            android:text="Mark as Paid"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_medium"
            android:visibility="gone" />

        <!-- Paid Label (shown when Paid) -->
        <TextView
            android:id="@+id/tvPaidLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/badge_status_done"
            android:gravity="center"
            android:padding="8dp"
            android:text="Paid ✓"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_medium"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>