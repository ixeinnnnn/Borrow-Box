<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_inventory.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Category Icon Badge -->
        <FrameLayout
            android:id="@+id/invIconBadge"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/badge_blue">

            <ImageView
                android:id="@+id/invIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_inventory"
                android:contentDescription="Item icon"
                app:tint="@color/badge_blue_icon" />
        </FrameLayout>

        <!-- Name + Category -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Folding Table"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tvInvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Furniture"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular" />
        </LinearLayout>

        <!-- Stock Info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvInvQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                android:gravity="end" />

            <TextView
                android:id="@+id/tvInvAvailable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8 available"
                android:textColor="@color/green_active"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="end" />
        </LinearLayout>

        <!-- Edit Button -->
        <ImageButton
            android:id="@+id/btnEditItem"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_circle_bg"
            android:src="@drawable/ic_edit"
            android:contentDescription="Edit item"
            app:tint="@color/text_secondary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>