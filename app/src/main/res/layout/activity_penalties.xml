<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_penalties.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- ── Toolbar with + button ───────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:title="Penalties"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:elevation="2dp">

        <ImageButton
            android:id="@+id/btnAddPenalty"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_circle_primary"
            android:src="@drawable/ic_add"
            android:contentDescription="Add Penalty"
            app:tint="@color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- ── Stat Cards: Unpaid + Collected ─────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingBottom="8dp">

        <!-- Total Unpaid -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/red_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Unpaid"
                    android:textSize="12sp"
                    android:textColor="@color/red_overdue"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/tvTotalUnpaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="₱0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/red_overdue"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Collected -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/green_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Collected"
                    android:textSize="12sp"
                    android:textColor="@color/green_active"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/tvTotalCollected"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="₱0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_active"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- ── Filter Chips ────────────────────────────────── -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipUnpaid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unpaid"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPaid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paid"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWaived"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waived"
            style="@style/Widget.MaterialComponents.Chip.Filter" />

    </com.google.android.material.chip.ChipGroup>

    <!-- ── Loading ProgressBar (THIS WAS MISSING) ─────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- ── Empty State (THIS WAS MISSING) ─────────────── -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="No penalty records found."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        android:visibility="gone" />

    <!-- ── Penalties RecyclerView ──────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPenalties"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>