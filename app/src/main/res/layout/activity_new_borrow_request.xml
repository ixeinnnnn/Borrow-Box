<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_new_borrow_request.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- ── Toolbar ─────────────────────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:title="New Borrow Request"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:elevation="2dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Selected Item Preview Card ──────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSelectedItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <!-- Item thumbnail -->
                    <ImageView
                        android:id="@+id/ivSelectedItemImage"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/badge_blue"
                        android:contentDescription="Selected item" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSelectedItemName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select a resource"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold" />

                        <TextView
                            android:id="@+id/tvSelectedItemCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="—"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_regular" />

                        <TextView
                            android:id="@+id/tvSelectedItemAvail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text=""
                            android:textColor="@color/orange_pending"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        android:contentDescription="Change resource"
                        app:tint="@color/hint_color" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Resource Label ───────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resource *"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="8dp" />

            <!-- Resource Dropdown (read-only, opens bottom sheet) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResourceDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider_color"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/tvResourceDropdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Select resource..."
                        android:textColor="@color/hint_color"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="270"
                        android:contentDescription="Dropdown"
                        app:tint="@color/hint_color" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Quantity ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantity *"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Minus button -->
                <Button
                    android:id="@+id/btnMinus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/card_rounded_white"
                    android:text="−"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold" />

                <!-- Quantity display -->
                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold" />

                <!-- Plus button -->
                <Button
                    android:id="@+id/btnPlus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/card_rounded_white"
                    android:text="+"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMaxQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Maximum: — pcs"
                android:textColor="@color/hint_color"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- ── Borrow Date + Return Date ─────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <!-- Borrow Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Borrow Date *"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBorrowDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="mm/dd/yyyy"
                            android:focusable="false"
                            android:clickable="true"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Return Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Return Date *"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_calendar">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReturnDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="mm/dd/yyyy"
                            android:focusable="false"
                            android:clickable="true"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins_regular" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Purpose ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Purpose *"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:counterEnabled="true"
                app:counterMaxLength="500">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPurpose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Describe the purpose of borrowing (e.g., community event, birthday celebration, barangay meeting...)"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="5"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Contact Number ────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Number *"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:startIconDrawable="@drawable/ic_location">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContactNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="0917-123-4567"
                    android:inputType="phone"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Additional Notes ──────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Additional Notes (Optional)"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Any special instructions or notes for the barangay staff..."
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="4"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Important Reminders Card ──────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF8E7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="top">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginTop="1dp"
                        android:src="@drawable/ic_warning"
                        android:contentDescription="Info"
                        app:tint="@color/orange_pending" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Important Reminders"
                            android:textColor="@color/orange_pending"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="• Resources must be returned on or before the return date\n• Late returns will incur a penalty fee of ₱50/day\n• Damaged items will be charged accordingly\n• Processing takes 1-2 business days"
                            android:textColor="@color/orange_pending"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.4"
                            android:fontFamily="@font/poppins_regular" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Submit Button ───────────────────────────────── -->
    <Button
        android:id="@+id/btnSubmitRequest"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="16dp"
        android:background="@drawable/btn_signin_bg"
        android:text="Submit Borrow Request"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_bold" />

</LinearLayout>